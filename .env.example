# ResQNet AI – Environment Variables
# Copy this file to .env and fill in your values

# Google Gemini API Key
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Application Mode: "live" or "simulation"
# If GEMINI_API_KEY is invalid, app auto-switches to simulation
APP_MODE=live

# Database path (default: local SQLite)
DATABASE_PATH=resqnet.db

# App settings
APP_TITLE=ResQNet AI
APP_VERSION=1.0.0
DEBUG=false
